# ─── Dalios Trading System — Environment Configuration ───────────────
# Copy this to .env and fill in your values.
# All keys are optional — the system degrades gracefully without them.

# ─── Trading Mode ────────────────────────────────────────────────────
TRADING_MODE=paper                    # paper | live

# ─── Database ────────────────────────────────────────────────────────
# SQLite (default, single-user):
DATABASE_URL=sqlite:///data/storage/trading.db
# PostgreSQL (production, multi-user):
# DATABASE_URL=postgresql://dalios:password@localhost:5432/dalios

# ─── Authentication (disabled by default) ────────────────────────────
# DALIOS_AUTH_ENABLED=true
# DALIOS_JWT_SECRET=your-64-char-random-secret-here
# DALIOS_JWT_EXPIRY_HOURS=24

# ─── Market Data APIs ───────────────────────────────────────────────
# yfinance is always available (no key needed)
# ALPHA_VANTAGE_API_KEY=            # Fallback price data (free: 5 req/min)
# EODHD_API_KEY=                    # Macro data - GDP, CPI (free tier limited)
# FINNHUB_API_KEY=                  # News articles (free: 60 req/min)
# NEWSAPI_API_KEY=                  # Market news (free: 100 req/day)

# ─── Notifications (optional) ───────────────────────────────────────
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Risk Parameters ────────────────────────────────────────────────
# MAX_DAILY_LOSS_PCT=2.0            # Circuit breaker: halt if daily loss > X%
# MAX_DRAWDOWN_PCT=10.0             # Circuit breaker: halt if drawdown > X%
# MAX_POS_SIZE_PCT=10.0             # Max % of portfolio in single position
# MAX_OPEN_POSITIONS=20             # Max concurrent open positions

# ─── API Security ───────────────────────────────────────────────────
# DALIOS_API_KEY=                   # Require X-API-Key header on /api/ routes
# DALIOS_CRED_KEY=                  # Encryption key for stored broker credentials
