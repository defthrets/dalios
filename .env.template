# ─── Dalios Trading System — Environment Configuration ───────────────
# Copy this file to .env and fill in your API keys.
# .env is gitignored — your secrets stay local.

# ─── Market Data APIs ────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
ITICK_API_KEY=

# ─── Macro Economic Data ─────────────────────────────────────────────
EODHD_API_KEY=
TRADING_ECONOMICS_API_KEY=

# ─── News APIs ────────────────────────────────────────────────────────
FINNHUB_API_KEY=
NEWSAPI_API_KEY=

# ─── Notifications ────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/storage/trading.db

# ─── Risk Parameters ─────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_PORTFOLIO_CORRELATION=0.3
MIN_DIVERSIFICATION_ASSETS=15

# ─── Trading Mode ─────────────────────────────────────────────────────
# "paper" = simulated trades only, "live" = real money via broker
TRADING_MODE=paper

# ─── API Security ─────────────────────────────────────────────────────
# Optional: set a key to require X-API-Key header on all API requests
# Leave empty to allow unauthenticated access (local-only use)
DALIOS_API_KEY=

# ─── License ──────────────────────────────────────────────────────────
# Master admin key — bypasses LemonSqueezy, instant offline activation
DALIOS_MASTER_KEY=
